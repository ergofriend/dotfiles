{
  "hooks": {
    "sessionStart": [
      {
        "command": "${HOME}/.apm/apm_modules/obra/superpowers/hooks/run-hook.cmd session-start",
        "_apm_source": "superpowers"
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.apm/apm_modules/obra/superpowers/hooks/run-hook.cmd\" session-start",
            "async": false
          }
        ],
        "_apm_source": "superpowers"
      }
    ]
  }
}
